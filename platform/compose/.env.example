# Copy to platform/compose/.env for local use.
# Do not commit platform/compose/.env.

POSTGRES_DB=accesshub_identity
POSTGRES_USER=accesshub
POSTGRES_PASSWORD=change-me-local-only
POSTGRES_PORT=5432

API_PORT=5080
ASPNETCORE_ENVIRONMENT=Development

JWT_ISSUER=AccessHub.Identity
JWT_AUDIENCE=AccessHub.Identity.Clients
JWT_SIGNING_KEY=replace-with-at-least-32-bytes-local-dev-key
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=15
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7
